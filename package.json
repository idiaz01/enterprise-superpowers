{
  "name": "enterprise-superpowers",
  "version": "0.4.0",
  "description": "CLI tool that scaffolds AI coding assistant plugins for enterprise teams. Generate Claude Code plugins with company branding, integrations, and enterprise-ready defaults.",
  "type": "module",
  "bin": {
    "enterprise-superpowers": "./dist/bin.js"
  },
  "files": [
    "dist",
    "templates",
    "content"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude-code",
    "plugin",
    "enterprise",
    "ai",
    "coding-assistant",
    "scaffolding",
    "cli",
    "developer-tools",
    "superpowers"
  ],
  "author": {
    "name": "Iván Díaz Garnacho"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/idiaz01/enterprise-superpowers.git"
  },
  "bugs": {
    "url": "https://github.com/idiaz01/enterprise-superpowers/issues"
  },
  "homepage": "https://github.com/idiaz01/enterprise-superpowers#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "handlebars": "^4.7.8",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.15.0",
    "eslint": "^9.25.0",
    "@eslint/js": "^9.25.0",
    "typescript-eslint": "^8.30.0",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
